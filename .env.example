# ─────────────────────────────────────────────────────────────────────────
# mcp-voicenotes-edit — environment template.
# Copy to `.env.development` for local `bun run server:mcp:dev`, or set these
# in your MCP client's `env` block. See README.md for full setup. `.env.*`
# files are gitignored; only `.env*.example` templates are committed.
# ─────────────────────────────────────────────────────────────────────────

# Voicenotes personal access token / account-scoped API token. The Bearer
# value the web app sends to /api/recordings (Laravel Sanctum `{id}|{secret}`).
# Grants full account access — treat it like a password. Required.
MCP_VOICENOTES_EDIT_PAT=your-voicenotes-pat-here

# Voicenotes API base URL. Default: https://api.voicenotes.com
# MCP_VOICENOTES_EDIT_BASE_URL=https://api.voicenotes.com

# ─────────────────────────────────────────────────────────────────────────
# Access level & audit log — conventions shared across all HNR MCP servers.
# ─────────────────────────────────────────────────────────────────────────

# Maximum access level to register at server boot. One of: read, write,
# destructive. Levels nest: `read` registers only read-only tools; `write`
# adds non-destructive mutations; `destructive` adds delete/overwrite tools.
# A tool's level is derived from its MCP annotations (readOnlyHint /
# destructiveHint), not its name — see src/utils/access-level.ts.
# Default: write.
# MCP_VOICENOTES_EDIT_ACCESS_LEVEL=destructive

# Audit log of tool invocations, written as JSONL. One of: off, writes, all.
#   off    — no audit logging
#   writes — record write/destructive calls only (default)
#   all    — record every call, including reads
# MCP_VOICENOTES_EDIT_AUDIT_LOG=writes

# Path to the audit log file.
# MCP_VOICENOTES_EDIT_AUDIT_LOG_PATH=~/.local/state/mcp-voicenotes-edit/audit.jsonl

# Rotate the audit log when it exceeds this many bytes (0 disables rotation).
# Default: 10485760 (10 MiB).
# MCP_VOICENOTES_EDIT_AUDIT_LOG_MAX_BYTES=10485760

# Number of rotated audit logs to keep. Default: 5.
# MCP_VOICENOTES_EDIT_AUDIT_LOG_KEEP=5
