{
  "name": "@knowledgeislands/mcp-voicenotes-edit",
  "description": "MCP server that edits Voicenotes recordings (tags, title) via the account-scoped web API",
  "version": "0.1.0",
  "author": "kris@kris.me.uk",
  "bin": {
    "mcp-voicenotes-edit": "dist/mcp-server/index.js"
  },
  "bugs": {
    "url": "https://github.com/knowledgeislands/mcp-voicenotes-edit/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "json5": "^2.2.3",
    "lint-staged": "^17.0.4",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "syncpack": "^15.1.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/knowledgeislands/mcp-voicenotes-edit#readme",
  "keywords": [
    "anthropic",
    "claude",
    "mcp",
    "model-context-protocol",
    "tags",
    "voicenotes"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched"
  },
  "main": "dist/mcp-server/index.js",
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/mcp-voicenotes-edit.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf {dist,node_modules}",
    "deps:missing": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.missing | keys | .[]' | xargs bun add -D",
    "deps:unused": "bunx depcheck --json | bunx node-jq --sort-keys '.' | bunx node-jq '.devDependencies[]' | xargs bun remove",
    "deps:update": "bun update",
    "lint:check": "bunx @biomejs/biome check",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe",
    "lint:format": "bunx @biomejs/biome format --write",
    "lint:md": "bunx prettier --write \"**/*.md\" --ignore-path .gitignore && bunx markdownlint-cli2",
    "lint:package": "bunx syncpack format",
    "lint:types": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "bun run build",
    "server:mcp:dev": "NODE_ENV=development bun --watch src/mcp-server/index.ts",
    "server:mcp:inspect": "NODE_ENV=development bunx @modelcontextprotocol/inspector bun src/mcp-server/index.ts",
    "server:mcp:start": "bun run build && node dist/mcp-server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "type": "module"
}
